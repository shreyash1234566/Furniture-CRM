generator client {
  provider = "prisma-client-js"
  runtime  = "nodejs"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

// ─── AUTH MODELS ─────────────────────────────────────

enum UserRole {
  ADMIN
  MANAGER
  STAFF
}

model User {
  id             Int       @id @default(autoincrement())
  email          String    @unique
  name           String
  hashedPassword String
  role           UserRole  @default(STAFF)
  isActive       Boolean   @default(true)
  staffId        Int?      @unique
  staff          Staff?    @relation(fields: [staffId], references: [id])
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  accounts Account[]
  sessions Session[]
}

model Account {
  id                Int     @id @default(autoincrement())
  userId            Int
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           Int      @id @default(autoincrement())
  sessionToken String   @unique
  userId       Int
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── CONTACT (Unified Customer Identity) ─────────────

model Contact {
  id        Int      @id @default(autoincrement())
  name      String
  phone     String   @unique
  email     String?
  address   String?
  gstNumber String?  // Buyer GSTIN — enables B2B classification in GSTR-1
  state     String?  // State for place of supply (e.g. "Maharashtra")
  source    String?
  notes             String?
  emailSubscribed   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  leads         Lead[]
  orders        Order[]
  appointments  Appointment[]
  invoices      Invoice[]
  quotations    Quotation[]
  customOrders  CustomOrder[]
  walkins       Walkin[]
  callLogs      CallLog[]
  conversations Conversation[]
  reviews       Review[]

  @@index([email])
  @@index([emailSubscribed])
}

// ─── LEAD MANAGEMENT ─────────────────────────────────

enum LeadStatus {
  NEW
  CONTACTED
  SHOWROOM_VISIT
  QUOTATION
  WON
  LOST
}

model Lead {
  id           Int        @id @default(autoincrement())
  contactId    Int
  contact      Contact    @relation(fields: [contactId], references: [id])
  interest     String
  budget       String?
  status       LeadStatus @default(NEW)
  source       String?
  date         DateTime   @default(now())
  notes        String?
  assignedToId Int?
  assignedTo   Staff?     @relation(fields: [assignedToId], references: [id])
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  followUps FollowUp[]

  @@index([status])
  @@index([date])
  @@index([assignedToId])
}

model FollowUp {
  id      Int      @id @default(autoincrement())
  leadId  Int
  lead    Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  day     Int
  message String
  sent    Boolean  @default(false)
  date    DateTime

  @@index([leadId])
}

// ─── PRODUCTS & INVENTORY ────────────────────────────

model Category {
  id       Int       @id @default(autoincrement())
  name     String    @unique
  products Product[]
}

model Warehouse {
  id       Int       @id @default(autoincrement())
  name     String    @unique
  address  String?
  products Product[]
}

model Product {
  id            Int        @id @default(autoincrement())
  sku           String     @unique
  name          String
  categoryId    Int
  category      Category   @relation(fields: [categoryId], references: [id])
  price         Int
  stock         Int        @default(0)
  sold          Int        @default(0)
  reorderLevel  Int        @default(5)
  image         String?
  material      String?
  color         String?
  description   String?
  warehouseId   Int?
  warehouse     Warehouse? @relation(fields: [warehouseId], references: [id])
  lastRestocked DateTime?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  orders              Order[]
  quotationItems      QuotationItem[]
  invoiceItems        InvoiceItem[]
  customOrders        CustomOrder[]
  purchaseOrderItems  PurchaseOrderItem[]
  purchaseReturnItems PurchaseReturnItem[]
  godownStocks        GodownStock[]
  transferItems       GodownTransferItem[]
  batches             ProductBatch[]
  bomItems            BomItem[]           @relation("RawMaterial")
  bomFinished         BillOfMaterials[]   @relation("FinishedProduct")
  productionFinished  ProductionOrder[]   @relation("ProductionFinished")
  materialConsumed    MaterialConsumption[] @relation("MaterialConsumed")
  stockLedger         StockLedger[]

  // Deep inventory fields
  hsnCode       String?
  unitOfMeasure String  @default("PCS")
  costPrice     Int     @default(0)
  stockGroupId  Int?
  stockGroup    StockGroup? @relation(fields: [stockGroupId], references: [id])

  @@index([categoryId])
  @@index([sku])
}

// ─── ORDERS ──────────────────────────────────────────

enum OrderStatus {
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum PaymentStatus {
  PAID
  PARTIAL
  PENDING
}

enum OrderSource {
  STORE
  AMAZON
  FLIPKART
  SHOPIFY
}

model Order {
  id           Int           @id @default(autoincrement())
  displayId    String        @unique
  contactId    Int
  contact      Contact       @relation(fields: [contactId], references: [id])
  productId    Int
  product      Product       @relation(fields: [productId], references: [id])
  quantity     Int           @default(1)
  amount       Int
  status       OrderStatus   @default(CONFIRMED)
  date         DateTime
  deliveryDate DateTime?
  payment      PaymentStatus @default(PENDING)
  source       OrderSource   @default(STORE)
  notes        String?
  godownId     Int?
  godown       Godown?       @relation(fields: [godownId], references: [id])
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([status])
  @@index([source])
  @@index([date])
  @@index([contactId])
}

// ─── QUOTATIONS ───────────────────────────────────────

enum QuotationStatus {
  DRAFT
  SENT
  APPROVED
  REJECTED
}

model Quotation {
  id                   Int             @id @default(autoincrement())
  displayId            String          @unique
  contactId            Int
  contact              Contact         @relation(fields: [contactId], references: [id])
  date                 DateTime        @default(now())
  validUntil           DateTime?
  projectName          String?
  deliveryMode         String?
  roadPermit           String?
  emailId              String?
  contactPerson        String?
  dispatchAddress      String?
  installationPercent  Float           @default(5)
  installationCharge   Int             @default(0)
  freightCharge        Int             @default(0)
  loadingCharge        Int             @default(0)
  gstPercent           Float           @default(18)
  gstAmount            Int             @default(0)
  totalBeforeTax       Int             @default(0)
  grandTotal           Int             @default(0)
  notes                String?
  termsAndConditions   String[]
  status               QuotationStatus @default(DRAFT)
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt

  items QuotationItem[]

  @@index([date])
  @@index([status])
  @@index([contactId])
}

model QuotationItem {
  id             Int        @id @default(autoincrement())
  quotationId    Int
  quotation      Quotation  @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  productId      Int?
  product        Product?   @relation(fields: [productId], references: [id])
  name           String
  sku            String?
  description    String?
  quantity       Int        @default(1)
  rate           Int
  amount         Int
  referenceImage String?
  sortOrder      Int        @default(0)

  @@index([quotationId])
  @@index([productId])
}

// ─── APPOINTMENTS ────────────────────────────────────

model Appointment {
  id        Int      @id @default(autoincrement())
  contactId Int
  contact   Contact  @relation(fields: [contactId], references: [id])
  date      DateTime
  time      String
  purpose   String
  status    String   @default("Scheduled")
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([date])
  @@index([status])
}

// ─── INVOICES & BILLING ──────────────────────────────

enum InvoiceStatus {
  ACTIVE
  CANCELLED
  REFUNDED
}

model Invoice {
  id            Int           @id @default(autoincrement())
  displayId     String        @unique
  contactId     Int
  contact       Contact       @relation(fields: [contactId], references: [id])
  subtotal      Int
  discount      Int           @default(0)
  discountType  String        @default("none")
  gst           Int           @default(0)
  cgst          Int           @default(0)
  sgst          Int           @default(0)
  igst          Int           @default(0)   // Interstate GST
  cess          Int           @default(0)   // Cess on applicable goods
  total         Int
  amountPaid    Int           @default(0)
  balanceDue    Int           @default(0)
  paymentMethod String        // primary payment method
  paymentStatus PaymentStatus @default(PENDING)
  invoiceStatus InvoiceStatus @default(ACTIVE)
  transportCost Int           @default(0)            // Transportation/freight cost added to invoice
  supplyType    String        @default("INTRASTATE") // INTRASTATE | INTERSTATE | EXPORT | EXEMPT | NIL_RATED
  placeOfSupply String?       // State name, e.g. "Maharashtra"
  isRCM         Boolean       @default(false)        // Reverse Charge Mechanism
  date          DateTime
  time          String?
  dueDate       DateTime?
  salespersonId Int?
  salesperson   Staff?        @relation(fields: [salespersonId], references: [id])
  notes         String?
  heldAt        DateTime?     // non-null = parked/held bill
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  items     InvoiceItem[]
  payments  Payment[]
  creditNotes CreditNote[]
  eWayBills   EWayBill[]

  @@index([date])
  @@index([paymentStatus])
  @@index([invoiceStatus])
  @@index([contactId])
}

model InvoiceItem {
  id        Int     @id @default(autoincrement())
  invoiceId Int
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  productId Int
  product   Product @relation(fields: [productId], references: [id])
  name      String
  sku       String
  quantity  Int
  price     Int
  hsnCode   String?  // HSN/SAC code for GST
  gstRate   Float    @default(18)  // Per-item GST rate (from HSN)
  cgst      Int      @default(0)   // Per-item CGST
  sgst      Int      @default(0)   // Per-item SGST
  igst      Int      @default(0)   // Per-item IGST (interstate)
  cess      Int      @default(0)   // Per-item cess
  taxableAmount Int  @default(0)   // price * quantity (pre-tax)

  @@index([invoiceId])
}

model Payment {
  id        Int      @id @default(autoincrement())
  invoiceId Int
  invoice   Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  amount    Int
  method    String   // Cash, UPI, Card, EMI, Bank Transfer, Cheque
  reference String?  // transaction ID, cheque number, etc.
  date      DateTime @default(now())
  notes     String?

  @@index([invoiceId])
  @@index([date])
}

model CreditNote {
  id          Int      @id @default(autoincrement())
  displayId   String   @unique
  invoiceId   Int
  invoice     Invoice  @relation(fields: [invoiceId], references: [id])
  amount      Int
  reason      String
  date        DateTime @default(now())
  createdAt   DateTime @default(now())

  @@index([invoiceId])
  @@index([date])
}

// ─── CUSTOM ORDERS ───────────────────────────────────

enum CustomOrderStatus {
  MEASUREMENT_SCHEDULED
  DESIGN_PHASE
  IN_PRODUCTION
  QUALITY_CHECK
  INSTALLATION
  DELIVERED
}

model CustomOrder {
  id               Int               @id @default(autoincrement())
  displayId        String            @unique
  contactId        Int
  contact          Contact           @relation(fields: [contactId], references: [id])
  phone            String
  address          String
  type             String
  status           CustomOrderStatus @default(MEASUREMENT_SCHEDULED)
  assignedStaffId  Int?
  assignedStaff    Staff?            @relation(fields: [assignedStaffId], references: [id])
  date             DateTime
  estimatedDelivery DateTime?
  measurements     Json?
  photos           String[]
  referenceImages  String[]          // uploaded reference images
  referenceProductId Int?
  referenceProduct Product?          @relation(fields: [referenceProductId], references: [id])
  materials        String?
  color            String?
  quotedPrice      Int?
  advancePaid      Int               @default(0)
  productionNotes  String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  timeline    CustomOrderTimeline[]
  fieldVisits FieldVisit[]

  @@index([status])
  @@index([assignedStaffId])
}

model CustomOrderTimeline {
  id            Int         @id @default(autoincrement())
  customOrderId Int
  customOrder   CustomOrder @relation(fields: [customOrderId], references: [id], onDelete: Cascade)
  date          DateTime
  event         String
  notes         String?
  status        String      @default("pending")
  updatedBy     String?     // "Manager" or staff name

  @@index([customOrderId])
}

// ─── WALK-INS ────────────────────────────────────────

enum WalkinStatus {
  BROWSING
  INTERESTED
  FOLLOW_UP
  CONVERTED
  LEFT
}

model Walkin {
  id           Int          @id @default(autoincrement())
  contactId    Int
  contact      Contact      @relation(fields: [contactId], references: [id])
  requirement  String
  assignedToId Int?
  assignedTo   Staff?       @relation("WalkinAssigned", fields: [assignedToId], references: [id])
  date         DateTime
  time         String
  status       WalkinStatus @default(BROWSING)
  budget       String?
  notes        String?
  source       String       @default("Walk-in")
  visitDuration String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([date])
  @@index([status])
}

// ─── STAFF ───────────────────────────────────────────

model Staff {
  id        Int      @id @default(autoincrement())
  name      String
  role      String
  phone     String
  email     String   @unique
  status    String   @default("Active")
  joinDate  DateTime
  avatar    String?
  stats     Json?
  target    Json?
  commission Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Payroll fields
  basicSalary          Int     @default(0)
  designation          String?
  panNumber            String?
  bankAccount          String?
  bankName             String?
  ifscCode             String?
  pfEnrolled           Boolean @default(false)
  esiEnrolled          Boolean @default(false)
  uanNumber            String?   // Universal Account Number (PF)
  pfNumber             String?   // PF registration number
  esiNumber            String?   // ESI registration number
  professionalTaxState String @default("Maharashtra")
  tdsMonthly           Int    @default(0)  // fixed monthly TDS amount

  user         User?
  leads        Lead[]
  invoices     Invoice[]
  customOrders CustomOrder[]
  walkins      Walkin[]         @relation("WalkinAssigned")
  attendance   Attendance[]
  activities   StaffActivity[]
  fieldVisits  FieldVisit[]
  stockUpdates StockUpdate[]
  payslips     Payslip[]
  loans        StaffLoan[]
  expenses     Expense[]        @relation("StaffExpenses")
  productionOrders ProductionOrder[] @relation("ProductionOrderAssignedStaff")

  @@index([email])
}

model Attendance {
  id            Int      @id @default(autoincrement())
  staffId       Int
  staff         Staff    @relation(fields: [staffId], references: [id], onDelete: Cascade)
  date          DateTime
  clockIn       String?
  clockOut      String?
  hours         Float?
  status        String
  // GPS tracking
  clockInLat    Float?
  clockInLng    Float?
  clockOutLat   Float?
  clockOutLng   Float?
  clockInDist   Float?   // distance from store in meters
  clockOutDist  Float?
  method        String   @default("manual") // "gps", "manual"
  isLate        Boolean  @default(false)

  @@unique([staffId, date])
  @@index([date])
}

model StaffActivity {
  id      Int      @id @default(autoincrement())
  staffId Int
  staff   Staff    @relation(fields: [staffId], references: [id], onDelete: Cascade)
  type    String
  text    String
  time    String
  date    DateTime

  @@index([staffId])
  @@index([date])
}

model FieldVisit {
  id             Int          @id @default(autoincrement())
  displayId      String
  staffId        Int
  staff          Staff        @relation(fields: [staffId], references: [id], onDelete: Cascade)
  customOrderId  Int?
  customOrder    CustomOrder? @relation(fields: [customOrderId], references: [id])
  customer       String
  address        String
  date           DateTime
  time           String
  scheduledDate  DateTime?    // when the visit is scheduled for
  scheduledTime  String?      // time slot e.g. "10:00 AM - 12:00 PM"
  status         String       // Scheduled, In Progress, Completed, Cancelled
  completedAt    DateTime?
  type           String
  notes          String?
  staffNotes     String?      // notes added by staff after visit
  measurements   Json?
  photos         Int          @default(0)
  photoUrls      String[]

  @@index([staffId])
  @@index([customOrderId])
  @@index([scheduledDate])
}

model StockUpdate {
  id        Int      @id @default(autoincrement())
  staffId   Int?
  staff     Staff?   @relation(fields: [staffId], references: [id])
  product   String
  warehouse String
  action    String
  quantity  Int
  date      DateTime
  time      String

  @@index([staffId])
  @@index([date])
}

// ─── CALL LOGS ───────────────────────────────────────

enum CallDirection {
  INBOUND
  OUTBOUND
}

enum CallStatus {
  COMPLETED
  MISSED
  NO_ANSWER
  BUSY
}

model CallLog {
  id           Int           @id @default(autoincrement())
  contactId    Int?
  contact      Contact?      @relation(fields: [contactId], references: [id])
  customerName String
  phone        String
  direction    CallDirection
  status       CallStatus
  duration     String?
  durationSec  Int           @default(0)
  agent        String        @default("AI Agent")
  date         DateTime
  time         String
  purpose      String?
  outcome      String?
  notes        String?
  recording    Boolean       @default(false)
  createdAt    DateTime      @default(now())

  // AI calling agent fields
  livekitRoomId String?
  callType      String?      @default("manual") // manual | ai_inbound | ai_outbound | browser_test
  aiHandled     Boolean      @default(false)

  transcript CallTranscript?

  @@index([date])
  @@index([contactId])
}

model CallTranscript {
  id        Int     @id @default(autoincrement())
  callLogId Int     @unique
  callLog   CallLog @relation(fields: [callLogId], references: [id], onDelete: Cascade)
  summary   String?
  sentiment String?
  messages  Json
}

// ─── CONVERSATIONS ───────────────────────────────────

enum ConversationStatus {
  AI_HANDLED
  NEEDS_HUMAN
  RESOLVED
}

model Conversation {
  id           Int                @id @default(autoincrement())
  contactId    Int?
  contact      Contact?           @relation(fields: [contactId], references: [id])
  customerName String
  channel      String
  externalId   String?            // platform-specific thread/chat ID (e.g. WhatsApp phone, IG thread)
  status       ConversationStatus @default(AI_HANDLED)
  lastMessage  String?
  unread       Int                @default(0)
  date         DateTime
  messages     Json
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  @@index([channel])
  @@index([status])
  @@index([externalId])
}

// ─── REVIEWS ─────────────────────────────────────────

model Review {
  id           Int      @id @default(autoincrement())
  contactId    Int?
  contact      Contact? @relation(fields: [contactId], references: [id])
  customerName String
  rating       Int
  text         String
  date         DateTime
  product      String
  platform     String   @default("Google")
  replied      Boolean  @default(false)
  createdAt    DateTime @default(now())

  @@index([rating])
  @@index([platform])
}

// ─── MARKETING CAMPAIGNS ─────────────────────────────

enum CampaignStatus {
  DRAFT
  SCHEDULED
  SENT
}

model Campaign {
  id            Int            @id @default(autoincrement())
  name          String
  channel       String
  status        CampaignStatus @default(DRAFT)
  scheduledDate DateTime?
  audience      Int            @default(0)
  sent          Int            @default(0)
  opened        Int            @default(0)
  clicked       Int            @default(0)
  template      String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

// ─── MARKETPLACE CHANNELS ────────────────────────────

model MarketplaceChannel {
  id        Int       @id @default(autoincrement())
  slug      String    @unique
  name      String
  logo      String?
  color     String?
  connected Boolean   @default(false)
  lastSync  DateTime?
  sellerId  String?
  config    Json?
}

// ─── STORE SETTINGS ──────────────────────────────────

model StoreSettings {
  id             Int      @id @default(1)
  storeName      String   @default("Furniture Store")
  phone          String?
  email          String?
  address        String?
  gstNumber      String?
  gstRate        Float    @default(18.0)
  currency       String   @default("INR")
  logo           String?
  // Geofence for GPS attendance
  storeLat       Float?
  storeLng       Float?
  geofenceRadius Int      @default(100) // meters
  shiftStartTime String   @default("09:00") // HH:mm — late after this
  shiftEndTime   String   @default("20:00") // HH:mm — shift ends
  // SMTP Email Configuration
  smtpHost       String?  // e.g. smtp.gmail.com, smtp.office365.com
  smtpPort       Int?     @default(587)
  smtpUser       String?  // email address used to send
  smtpPass       String?  // app password / SMTP password
  smtpFromName   String?  // "Furniture Store" — display name in From header
  smtpSecure     Boolean  @default(false) // true for port 465 (SSL), false for 587 (STARTTLS)
  smtpConfigured Boolean  @default(false) // true once test email succeeds
  updatedAt      DateTime @updatedAt
}

// ─── IN-APP NOTIFICATIONS ───────────────────────────

model Notification {
  id        Int      @id @default(autoincrement())
  type      String   // 'stock_alert' | 'field_visit'
  title     String
  subtitle  String
  href      String   // link to navigate to
  read      Boolean  @default(false)
  metadata  Json?    // extra data (productId, visitId, etc.)
  createdAt DateTime @default(now())

  @@index([read])
  @@index([type])
}

// ─── STORE CAMPAIGNS (QR Codes) ──────────────────────

model StoreCampaign {
  id        Int      @id @default(autoincrement())
  name      String
  type      String
  location  String
  scans     Int      @default(0)
  leads     Int      @default(0)
  status    String   @default("Active")
  purpose   String?
  createdAt DateTime @default(now())
}

// ─── CHANNEL INTEGRATIONS ────────────────────────────

model ChannelConfig {
  id          Int      @id @default(autoincrement())
  channel     String   @unique // WhatsApp, Instagram, Facebook, Website
  enabled     Boolean  @default(false)
  config      Json     // API keys, tokens, phone numbers, page IDs, etc.
  webhookUrl  String?  // auto-generated webhook URL for this channel
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─── EMAIL MARKETING ────────────────────────────────

model EmailTemplate {
  id          Int      @id @default(autoincrement())
  name        String
  subject     String
  body        String   @db.Text // HTML body
  category    String   @default("Promotional") // Promotional, Follow-up, New Collection, Offer, Nurture
  variables   String[] // e.g. ["customerName", "offerCode"]
  thumbnail   String?  // preview image
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  campaigns EmailCampaign[]
}

enum EmailCampaignStatus {
  DRAFT
  SCHEDULED
  SENDING
  SENT
  PAUSED
}

model EmailCampaign {
  id             Int                 @id @default(autoincrement())
  name           String
  subject        String
  body           String              @db.Text
  templateId     Int?
  template       EmailTemplate?      @relation(fields: [templateId], references: [id])
  status         EmailCampaignStatus @default(DRAFT)
  scheduledAt    DateTime?
  sentAt         DateTime?
  audience       String              @default("all") // all, leads, customers, custom
  audienceFilter Json?               // filter criteria for custom audience
  totalRecipients Int               @default(0)
  sent           Int                 @default(0)
  opened         Int                 @default(0)
  clicked        Int                 @default(0)
  bounced        Int                 @default(0)
  unsubscribed   Int                 @default(0)
  // A/B testing
  isABTest       Boolean             @default(false)
  variantB       Json?               // { subject, body } for variant B
  abSplitPercent Int                 @default(50) // % that get variant A
  abWinner       String?             // "A" or "B"
  // Automation
  isAutomated    Boolean             @default(false)
  triggerType    String?             // "new_lead", "post_visit", "abandoned_quote", "post_purchase"
  triggerDelay   Int?                // delay in hours after trigger event
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  recipients EmailRecipient[]

  @@index([status])
  @@index([isAutomated, triggerType])
}

model EmailRecipient {
  id           Int      @id @default(autoincrement())
  campaignId   Int
  campaign     EmailCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  contactId    Int?
  email        String
  name         String
  variant      String   @default("A") // A or B for A/B tests
  status       String   @default("queued") // queued, sent, delivered, opened, clicked, bounced, unsubscribed
  sentAt       DateTime?
  openedAt     DateTime?
  clickedAt    DateTime?
  bouncedAt    DateTime?
  opens        Int      @default(0)
  clicks       Int      @default(0)

  events EmailEvent[]

  @@index([campaignId])
  @@index([email])
  @@index([status])
}

model EmailEvent {
  id           Int      @id @default(autoincrement())
  recipientId  Int
  recipient    EmailRecipient @relation(fields: [recipientId], references: [id], onDelete: Cascade)
  type         String   // open, click, bounce, unsubscribe
  metadata     Json?    // { url, userAgent, ip, etc. }
  createdAt    DateTime @default(now())

  @@index([recipientId])
  @@index([type])
  @@index([createdAt])
}

// ─── DRAFTS (soft-delete, auto-purge after 30 days) ───

model Draft {
  id          Int      @id @default(autoincrement())
  sourceType  String   // "CustomOrder", "Lead", etc.
  sourceId    String   // original displayId for reference
  data        Json     // full snapshot of the deleted record
  deletedBy   String   @default("Manager")
  deletedAt   DateTime @default(now())
  expiresAt   DateTime // deletedAt + 30 days

  @@index([sourceType])
  @@index([expiresAt])
}

// ─── MODULE 1: PURCHASE MANAGEMENT ──────────────────

enum POStatus {
  DRAFT
  APPROVED
  PARTIALLY_RECEIVED
  RECEIVED
  CANCELLED
}

model Supplier {
  id             Int      @id @default(autoincrement())
  name           String
  gstNumber      String?
  phone          String?
  email          String?
  address        String?
  contactPerson  String?
  paymentTerms   Int      @default(30)
  openingBalance Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  purchaseOrders  PurchaseOrder[]
  purchaseReturns PurchaseReturn[]
}

model PurchaseOrder {
  id           Int      @id @default(autoincrement())
  displayId    String   @unique
  supplierId   Int
  supplier     Supplier @relation(fields: [supplierId], references: [id])
  status       POStatus @default(DRAFT)
  subtotal     Int      @default(0)
  discount     Int      @default(0)
  gst          Int      @default(0)
  cgst         Int      @default(0)
  sgst         Int      @default(0)
  igst         Int      @default(0)   // Interstate purchases
  total        Int      @default(0)
  amountPaid   Int      @default(0)
  balanceDue   Int      @default(0)
  isRCM        Boolean  @default(false) // Reverse Charge Mechanism
  itcEligible  Boolean  @default(true)  // Is ITC claimable?
  itcCategory  String   @default("INPUTS") // INPUTS | SERVICES | CAPITAL_GOODS | INELIGIBLE
  date         DateTime @default(now())
  expectedDate DateTime?
  receivedAt   DateTime?
  notes        String?
  createdBy    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  items           PurchaseOrderItem[]
  payments        PurchasePayment[]
  purchaseReturns PurchaseReturn[]

  @@index([supplierId])
  @@index([status])
}

model PurchaseOrderItem {
  id          Int           @id @default(autoincrement())
  poId        Int
  po          PurchaseOrder @relation(fields: [poId], references: [id], onDelete: Cascade)
  productId   Int
  product     Product       @relation(fields: [productId], references: [id])
  name        String
  sku         String
  hsnCode     String?
  quantity    Int
  receivedQty Int           @default(0)
  unitCost    Int
  gstRate     Float         @default(18)
  amount      Int

  @@index([poId])
}

model PurchaseReturn {
  id          Int            @id @default(autoincrement())
  displayId   String         @unique
  poId        Int?
  po          PurchaseOrder? @relation(fields: [poId], references: [id])
  supplierId  Int
  supplier    Supplier       @relation(fields: [supplierId], references: [id])
  reason      String
  totalAmount Int
  date        DateTime       @default(now())
  status      String         @default("Pending")
  notes       String?
  createdAt   DateTime       @default(now())

  items PurchaseReturnItem[]

  @@index([supplierId])
}

model PurchaseReturnItem {
  id        Int            @id @default(autoincrement())
  returnId  Int
  return    PurchaseReturn @relation(fields: [returnId], references: [id], onDelete: Cascade)
  productId Int
  product   Product        @relation(fields: [productId], references: [id])
  name      String
  sku       String
  quantity  Int
  unitCost  Int

  @@index([returnId])
}

model PurchasePayment {
  id        Int           @id @default(autoincrement())
  poId      Int
  po        PurchaseOrder @relation(fields: [poId], references: [id], onDelete: Cascade)
  amount    Int
  method    String        @default("Bank Transfer") // Cash, UPI, Card, Bank Transfer, Cheque
  reference String?
  notes     String?
  paidAt    DateTime      @default(now())
  createdBy String?
  createdAt DateTime      @default(now())

  @@index([poId])
  @@index([paidAt])
}

// ─── MODULE 2: MULTI-BRANCH / GODOWN ────────────────

model Branch {
  id           Int      @id @default(autoincrement())
  name         String
  address      String?
  phone        String?
  email        String?
  managerName  String?
  isHeadOffice Boolean  @default(false)
  createdAt    DateTime @default(now())

  godowns Godown[]
}

model Godown {
  id        Int      @id @default(autoincrement())
  name      String
  address   String?
  type      String   @default("Warehouse") // Warehouse, Showroom, Factory
  capacity  Int?     // max item capacity
  isDefault Boolean  @default(false)        // primary godown for stock ops
  branchId  Int?
  branch    Branch?  @relation(fields: [branchId], references: [id])
  createdAt DateTime @default(now())

  stocks        GodownStock[]
  transfersFrom GodownTransfer[] @relation("FromGodown")
  transfersTo   GodownTransfer[] @relation("ToGodown")
  ledgerEntries StockLedger[]
  orders        Order[]

  @@index([branchId])
}

model GodownStock {
  id        Int     @id @default(autoincrement())
  productId Int
  product   Product @relation(fields: [productId], references: [id])
  godownId  Int
  godown    Godown  @relation(fields: [godownId], references: [id])
  quantity  Int     @default(0)

  @@unique([productId, godownId])
  @@index([godownId])
}

model GodownTransfer {
  id           Int      @id @default(autoincrement())
  displayId    String   @unique
  fromGodownId Int
  fromGodown   Godown   @relation("FromGodown", fields: [fromGodownId], references: [id])
  toGodownId   Int
  toGodown     Godown   @relation("ToGodown", fields: [toGodownId], references: [id])
  status       String   @default("Pending")
  date         DateTime @default(now())
  notes        String?
  requestedBy  String?
  approvedBy   String?
  createdAt    DateTime @default(now())

  items GodownTransferItem[]

  @@index([fromGodownId])
  @@index([toGodownId])
}

model GodownTransferItem {
  id         Int            @id @default(autoincrement())
  transferId Int
  transfer   GodownTransfer @relation(fields: [transferId], references: [id], onDelete: Cascade)
  productId  Int
  product    Product        @relation(fields: [productId], references: [id])
  name       String
  sku        String
  quantity   Int

  @@index([transferId])
}

model StockLedger {
  id            Int      @id @default(autoincrement())
  productId     Int
  product       Product  @relation(fields: [productId], references: [id])
  godownId      Int
  godown        Godown   @relation(fields: [godownId], references: [id])
  entryType     String   // IN, OUT, TRANSFER_IN, TRANSFER_OUT, ADJUSTMENT, PRODUCTION, SALE, RETURN
  quantity      Int      // positive = in, negative = out
  balanceAfter  Int      // running balance at godown after entry
  referenceType String?  // Order, Transfer, Production, Manual
  referenceId   Int?
  notes         String?
  createdBy     String?
  createdAt     DateTime @default(now())

  @@index([productId])
  @@index([godownId])
  @@index([createdAt])
}

// ─── MODULE 3: DEEP INVENTORY ────────────────────────

model StockGroup {
  id        Int          @id @default(autoincrement())
  name      String       @unique
  parentId  Int?
  parent    StockGroup?  @relation("StockGroupHierarchy", fields: [parentId], references: [id])
  children  StockGroup[] @relation("StockGroupHierarchy")
  createdAt DateTime     @default(now())

  products Product[]
}

model ProductBatch {
  id           Int      @id @default(autoincrement())
  productId    Int
  product      Product  @relation(fields: [productId], references: [id])
  batchNumber  String
  purchaseDate DateTime @default(now())
  expiryDate   DateTime?
  quantity     Int
  remainingQty Int
  costPrice    Int      @default(0)
  supplierId   Int?
  poId         Int?
  createdAt    DateTime @default(now())

  @@unique([productId, batchNumber])
  @@index([productId])
}

// ─── MODULE 4: GST COMPLIANCE ────────────────────────

model HsnCode {
  id          Int      @id @default(autoincrement())
  code        String   @unique
  description String
  gstRate     Float    @default(18)
  cessRate    Float    @default(0)
  type        String   @default("GOODS")
  createdAt   DateTime @default(now())
}

model GSTReturn {
  id         Int      @id @default(autoincrement())
  returnType String
  period     String
  status     String   @default("DRAFT")
  filedAt    DateTime?
  data       Json
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([returnType, period])
  @@index([period])
}

model EWayBill {
  id               Int      @id @default(autoincrement())
  ewbNumber        String?  // e-Way Bill number from portal
  invoiceId        Int?
  invoice          Invoice? @relation(fields: [invoiceId], references: [id])
  vehicleNo        String?
  transporterGSTIN String?
  transporterName  String?
  fromAddress      String?
  toAddress        String?
  distance         Int?     // km
  goodsDesc        String?
  hsnCode          String?
  quantity         Float?
  value            Int      @default(0)  // Invoice value
  validFrom        DateTime?
  validUntil       DateTime?
  status           String   @default("GENERATED") // GENERATED | CANCELLED | EXPIRED
  notes            String?
  createdAt        DateTime @default(now())

  @@index([invoiceId])
  @@index([status])
}

// ─── MODULE 5: MANUFACTURING / JOB COSTING ──────────

model WorkCenter {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  type        String   @default("General") // Carpentry | Polishing | Upholstery | Finishing | Assembly | QC | Packaging | General
  description String?
  capacity    Int      @default(1)          // units producible per day
  status      String   @default("Active")   // Active | Maintenance | Inactive
  notes       String?
  createdAt   DateTime @default(now())

  productionOrders ProductionOrder[]
  steps            ProductionStep[]
  bomSteps         BomStep[]
}

model BillOfMaterials {
  id                Int      @id @default(autoincrement())
  name              String
  finishedProductId Int
  finishedProduct   Product  @relation("FinishedProduct", fields: [finishedProductId], references: [id])
  version           String   @default("1.0")
  isActive          Boolean  @default(true)
  estimatedDays     Int?                   // expected production days
  notes             String?
  createdAt         DateTime @default(now())

  items            BomItem[]
  steps            BomStep[]
  productionOrders ProductionOrder[]

  @@index([finishedProductId])
}

model BomItem {
  id              Int             @id @default(autoincrement())
  bomId           Int
  bom             BillOfMaterials @relation(fields: [bomId], references: [id], onDelete: Cascade)
  rawMaterialId   Int
  rawMaterial     Product         @relation("RawMaterial", fields: [rawMaterialId], references: [id])
  quantity        Float
  unitOfMeasure   String          @default("PCS")
  wastagePercent  Float           @default(0)
  unitCost        Float           @default(0) // override costPrice from product
  notes           String?

  @@index([bomId])
}

// Manufacturing routing — step-by-step operations defined on a BOM
model BomStep {
  id                 Int             @id @default(autoincrement())
  bomId              Int
  bom                BillOfMaterials @relation(fields: [bomId], references: [id], onDelete: Cascade)
  stepNumber         Int
  operationName      String          // e.g. "Cut & Shape", "Polish", "Upholster"
  workCenterId       Int?
  workCenter         WorkCenter?     @relation(fields: [workCenterId], references: [id])
  durationMins       Int             @default(60)  // per unit, in minutes
  labourRatePerHour  Float           @default(0)   // ₹ per hour for this operation
  machineCostPerUnit Float           @default(0)   // ₹ machine cost per unit (manual)
  notes              String?

  @@index([bomId])
}

// ─── BOM TEMPLATE ────────────────────────────────────
// Reusable routing/step templates for products with same manufacturing process
model BomTemplate {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?
  steps       Json     // array of step objects
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ProductionOrder {
  id                Int             @id @default(autoincrement())
  displayId         String          @unique
  bomId             Int
  bom               BillOfMaterials @relation(fields: [bomId], references: [id])
  finishedProductId Int
  finishedProduct   Product         @relation("ProductionFinished", fields: [finishedProductId], references: [id])
  workCenterId      Int?
  workCenter        WorkCenter?     @relation(fields: [workCenterId], references: [id])
  plannedQty        Int
  actualQty         Int             @default(0)
  status            String          @default("PLANNED")  // PLANNED | IN_PROGRESS | COMPLETED | CANCELLED | ON_HOLD
  priority          String          @default("MEDIUM")   // LOW | MEDIUM | HIGH | URGENT
  dueDate           DateTime?
  startDate         DateTime?
  completedDate     DateTime?
  cancelledDate     DateTime?
  cancelReason      String?
  totalMaterialCost Int             @default(0)
  totalLabourCost   Int             @default(0)
  overheadCost      Int             @default(0)          // electricity, tool wear, etc.
  totalCost         Int             @default(0)          // material + labour + overhead
  costPerUnit       Int             @default(0)
  yieldRate         Float           @default(0)          // actualQty/plannedQty * 100
  scrapQty          Int             @default(0)
  scrapReason       String?
  qualityStatus     String          @default("PENDING")  // PENDING | PASSED | FAILED | PARTIAL
  qualityNotes      String?
  assignedStaffId   Int?
  assignedStaff     Staff?          @relation("ProductionOrderAssignedStaff", fields: [assignedStaffId], references: [id])
  assignedTo        String?          // legacy/manual assignee text fallback
  notes             String?
  createdBy         String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  consumptions   MaterialConsumption[]
  productionSteps ProductionStep[]

  @@index([status])
  @@index([priority])
  @@index([dueDate])
  @@index([assignedStaffId])
}

// Tracks progress of each BOM step within a production order
model ProductionStep {
  id                Int             @id @default(autoincrement())
  productionOrderId Int
  productionOrder   ProductionOrder @relation(fields: [productionOrderId], references: [id], onDelete: Cascade)
  workCenterId      Int?
  workCenter        WorkCenter?     @relation(fields: [workCenterId], references: [id])
  stepNumber        Int
  operationName     String
  status            String          @default("PENDING") // PENDING | IN_PROGRESS | DONE | SKIPPED
  plannedMins       Int             @default(0)
  actualMins        Int             @default(0)
  assignedWorker    String?
  startedAt         DateTime?
  completedAt       DateTime?
  notes             String?

  @@index([productionOrderId])
}

model MaterialConsumption {
  id                Int             @id @default(autoincrement())
  productionOrderId Int
  productionOrder   ProductionOrder @relation(fields: [productionOrderId], references: [id], onDelete: Cascade)
  rawMaterialId     Int
  rawMaterial       Product         @relation("MaterialConsumed", fields: [rawMaterialId], references: [id])
  plannedQty        Float
  actualQty         Float           @default(0)
  unitCost          Int             @default(0)
  totalCost         Int             @default(0)

  @@index([productionOrderId])
}

// ─── MODULE 6: STAFF PAYROLL ─────────────────────────

model PayrollRun {
  id                   Int      @id @default(autoincrement())
  displayId            String   @unique
  period               String
  status               String   @default("DRAFT")
  totalGross           Int      @default(0)
  totalDeductions      Int      @default(0)
  totalNet             Int      @default(0)
  employerContributions Int     @default(0)  // total employer PF + ESI
  processedAt          DateTime @default(now())
  paidAt               DateTime?
  processedBy          String?
  createdAt            DateTime @default(now())

  payslips Payslip[]

  @@index([status])
}

model Payslip {
  id               Int        @id @default(autoincrement())
  payrollRunId     Int
  payrollRun       PayrollRun @relation(fields: [payrollRunId], references: [id], onDelete: Cascade)
  staffId          Int
  staff            Staff      @relation(fields: [staffId], references: [id])
  workingDays      Int        @default(26)
  presentDays      Int        @default(0)
  basicSalary      Int        @default(0)
  hra              Int        @default(0)
  da               Int        @default(0)
  specialAllowance Int        @default(0)
  otHours          Float      @default(0)
  otPay            Int        @default(0)
  bonus            Int        @default(0)
  grossSalary      Int        @default(0)
  pfEmployee       Int        @default(0)
  pfEmployer       Int        @default(0)
  esiEmployee      Int        @default(0)
  esiEmployer      Int        @default(0)
  professionalTax  Int        @default(0)
  tds              Int        @default(0)
  loanDeduction    Int        @default(0)
  otherDeductions  Int        @default(0)
  totalDeductions  Int        @default(0)
  netSalary        Int        @default(0)
  status           String     @default("Generated")
  createdAt        DateTime   @default(now())

  @@unique([payrollRunId, staffId])
  @@index([staffId])
}

model StaffLoan {
  id                Int      @id @default(autoincrement())
  staffId           Int
  staff             Staff    @relation(fields: [staffId], references: [id], onDelete: Cascade)
  purpose           String
  principalAmount   Int
  remainingAmount   Int
  monthlyInstallment Int
  startPeriod       String   // YYYY-MM
  status            String   @default("Active")  // Active, Closed
  notes             String?
  createdAt         DateTime @default(now())

  @@index([staffId])
  @@index([status])
}

// ─── DAILY EXPENSE CALCULATOR ────────────────────────

model ExpenseCategory {
  id          Int       @id @default(autoincrement())
  name        String    @unique
  icon        String?   // lucide icon name for UI
  color       String?   // hex color for charts
  budget      Int       @default(0)   // monthly budget limit (₹)
  isDefault   Boolean   @default(false)
  isActive    Boolean   @default(true)
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())
  expenses    Expense[]
  recurringExpenses RecurringExpense[]
}

model Expense {
  id           Int             @id @default(autoincrement())
  date         DateTime
  categoryId   Int
  category     ExpenseCategory @relation(fields: [categoryId], references: [id])
  amount       Int             // amount in paise-free ₹ (whole rupees)
  description  String
  paymentMode  String          @default("Cash") // Cash, UPI, Card, Bank Transfer, Cheque, Credit
  reference    String?         // bill/receipt number, UPI ref, cheque no
  receipt      String?         // uploaded receipt image URL
  vendor       String?         // who was paid
  staffId      Int?            // which staff member incurred expense
  staff        Staff?          @relation("StaffExpenses", fields: [staffId], references: [id])
  status       String          @default("Approved") // Pending, Approved, Rejected
  approvedBy   String?
  isRecurring  Boolean         @default(false)
  notes        String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@index([date])
  @@index([categoryId])
  @@index([status])
  @@index([staffId])
}

model RecurringExpense {
  id           Int             @id @default(autoincrement())
  categoryId   Int
  category     ExpenseCategory @relation(fields: [categoryId], references: [id])
  description  String
  amount       Int
  paymentMode  String          @default("Bank Transfer")
  vendor       String?
  frequency    String          @default("Monthly") // Daily, Weekly, Monthly, Quarterly, Yearly
  dayOfMonth   Int?            // 1-31 for monthly
  dayOfWeek    Int?            // 0-6 for weekly (0=Sunday)
  isActive     Boolean         @default(true)
  startDate    DateTime        @default(now())
  endDate      DateTime?
  lastRun      DateTime?
  notes        String?
  createdAt    DateTime        @default(now())

  @@index([isActive])
  @@index([frequency])
}

model DailyCashRegister {
  id             Int      @id @default(autoincrement())
  date           DateTime @unique
  openingCash    Int      @default(0)
  closingCash    Int?
  cashIn         Int      @default(0)  // cash received (sales etc)
  cashOut        Int      @default(0)  // cash expenses
  notes          String?
  closedBy       String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([date])
}

// ─── MODULE 7: FINANCIAL STATEMENTS ─────────────────

model AccountGroup {
  id       Int      @id @default(autoincrement())
  name     String   @unique
  type     String   // ASSET | LIABILITY | INCOME | EXPENSE | EQUITY
  parentId Int?
  parent   AccountGroup?  @relation("AccountGroupHierarchy", fields: [parentId], references: [id])
  children AccountGroup[] @relation("AccountGroupHierarchy")

  accounts LedgerAccount[]
}

model LedgerAccount {
  id              Int          @id @default(autoincrement())
  code            String       @unique
  name            String
  groupId         Int
  group           AccountGroup @relation(fields: [groupId], references: [id])
  openingBalance  Int          @default(0)
  isSystemAccount Boolean      @default(false)
  createdAt       DateTime     @default(now())

  lines JournalLine[]

  @@index([groupId])
}

model JournalEntry {
  id            Int      @id @default(autoincrement())
  displayId     String   @unique
  date          DateTime
  narration     String
  referenceType String?
  referenceId   Int?
  totalDebit    Int
  totalCredit   Int
  status        String   @default("POSTED")
  createdBy     String?
  createdAt     DateTime @default(now())

  lines JournalLine[]

  @@index([date])
  @@index([status])
}

model JournalLine {
  id             Int           @id @default(autoincrement())
  journalEntryId Int
  journalEntry   JournalEntry  @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  accountId      Int
  account        LedgerAccount @relation(fields: [accountId], references: [id])
  debit          Int           @default(0)
  credit         Int           @default(0)
  description    String?

  @@index([journalEntryId])
  @@index([accountId])
}
